  commitment: 'confirmed', // optional (default)
})
```

### Lifecycle

```typescript
await sdk.connect() // Connect WebSocket, fetch init data, sync slot
sdk.disconnect() // Disconnect, stop slot tracker, clear cache
sdk.isConnected // boolean
```

### Real-Time Events

```typescript
const unsub = sdk.on('board', (board) => { ... })
unsub() // or sdk.off('board', handler)
```

| Event           | Type            | Description                                        |
| --------------- | --------------- | -------------------------------------------------- |
| `board`         | `Board`         | Round boundaries (roundId, startSlot, endSlot)     |
| `round`         | `Round`         | Grid state: deployed[25], count[25], totals        |
| `resetEvent`    | `ResetEvent`    | Round result: winningSquare, winners, payouts      |
| `treasury`      | `Treasury`      | Treasury balances, reward factors, staking totals  |
| `miner`         | `Miner`         | Your miner account (deployed, rewards, checkpoint) |
| `automation`    | `Automation`    | Your autominer config and balance                  |
| `slotData`      | `SlotData`      | Slot sync from server                              |
| `solMotherlode` | `SolMotherlode` | Current SOL jackpot amount                         |
| `poolMember`    | `PoolMember`    | Your pool membership data                          |
| `poolRound`     | `PoolRound`     | Pool round deployments                             |
| `slotTick`      | `bigint`        | Emitted every ~400ms with estimated slot           |
| `connected`     | `boolean`       | WebSocket connection state                         |
| `error`         | `Error`         | WebSocket errors                                   |

### Slot Tracking

```typescript
const currentSlot = sdk.getSlot() // bigint

const unsub = sdk.onSlotTick((slot) => {
  // fires every ~400ms
  const board = await sdk.getBoard()
  const remaining = board.endSlot - slot
  console.log('Slots remaining:', remaining)
})
```

### Account Getters

All getters use a two-tier cache (WebSocket → 15s in-memory cache → stream API / RPC fallback).

```typescript
// Global state
const board = await sdk.getBoard() // Board { roundId, startSlot, endSlot }
const treasury = await sdk.getTreasury() // Treasury { balance, motherlode, totalStaked, ... }
const config = await sdk.getConfig() // Config { admin, godlPerRound, varAddress, ... }

// Per-user (defaults to signer if authority omitted)
const miner = await sdk.getMiner() // throws if not found
const miner2 = await sdk.getMiner('SomePubkey...') // other user's miner
const automation = await sdk.getAutomation() // null if not set up
const stake = await sdk.getStake() // V1 stake
const stakeV2 = await sdk.getStakeV2(0n) // V2 stake by ID
const allStakes = await sdk.getStakeV2Accounts() // all V2 stakes

// Round data
const round = await sdk.getRound(42n) // null if not found
const poolRound = await sdk.getPoolRound(42n) // null if not found

// Pool & referral
const poolMember = await sdk.getPoolMember() // null if not a member
const referrer = await sdk.getReferrer() // null if not a referrer
```

